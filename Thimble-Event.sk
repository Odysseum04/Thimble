#
# ╔══════════════════════════════════════════════════════════╗
# ║           Thimble Event - Dé à Coudre Minigame           ║
# ║   Compatible : Skript 2.9+ | Minecraft 1.21.x            ║
# ║   Aucun addon requis                                     ║
# ╠══════════════════════════════════════════════════════════╣
# ║  Auteur  : Clément Raes (Odysseum04)                     ║
# ║  GitHub  : https://github.com/odysseum04                 ║
# ║  Note    : Script généré avec l'assistance de Claude AI  ║
# ╠══════════════════════════════════════════════════════════╣
# ║  Mécaniques :                                            ║
# ║   - Un seul joueur est actif (survie) à la fois          ║
# ║   - Marcher sur une éponge mouillée → saut réussi        ║
# ║   - Recevoir des dégâts (raté le bassin) → élimination   ║
# ║   - Le bassin rétrécit au fil des tours                  ║
# ║   - Le dernier survivant remporte la partie              ║
# ╠══════════════════════════════════════════════════════════╣
# ║  Commandes (permission : events.admin) :                 ║
# ║   /te setspawn  → Définit le point de départ             ║
# ║   /te start     → Lance la partie                        ║
# ║   /te stop      → Arrête la partie en cours              ║
# ║   /te info      → Affiche l'état du jeu                  ║
# ╚══════════════════════════════════════════════════════════╝
#

options:
    prefix: &r[&aSERVER-NAME &cEvents&r]
    perm-admin: events.admin
    world-name: world

function te_playerWorldName(p: player) :: text:
    return "%world of {_p}%"

function te_isInConfiguredWorld(p: player) :: boolean:
    if te_playerWorldName({_p}) is "{@world-name}":
        return true
    return false

function te_setWaiting(p: player):
    set {te.%uuid of {_p}%.playing} to false
    teleport {_p} to {te.spawn}
    set game mode of {_p} to spectator
    send title "" with subtitle "&eAttendez votre tour de sauter..." to {_p} for 1 hour

function te_setSpectating(p: player):
    set {te.%uuid of {_p}%.playing} to false
    teleport {_p} to {te.spawn}
    set game mode of {_p} to spectator
    send title "&c✗ Éliminé !" with subtitle "&7Vous avez raté votre saut..." to {_p} for 5 seconds
    play sound "entity.player.death" to {_p}

function te_setPlaying(p: player):
    set {te.%uuid of {_p}%.playing} to true
    teleport {_p} to {te.spawn}
    heal {_p}
    set food level of {_p} to 20
    set game mode of {_p} to survival
    send title "&e➤ À vous de sauter !" with subtitle "&7Visez le bassin !" to {_p} for 3 seconds
    play sound "block.note_block.pling" to {_p}
    remove {_p} from {te.vague::*}

function te_cleanLists():
    loop {te.joueurs::*}:
        if loop-value is not a player:
            remove loop-value from {te.joueurs::*}
    loop {te.vague::*}:
        if loop-value is not a player:
            remove loop-value from {te.vague::*}

function te_nextPlayer():
    if {te.running} is not true:
        stop
    wait 2 seconds
    if {te.running} is not true:
        stop
    te_cleanLists()
    if size of {te.joueurs::*} <= 1:
        te_endGame()
        stop
    if size of {te.vague::*} <= 0:
        loop {te.joueurs::*}:
            add loop-value to {te.vague::*}
    set {_next} to last element of {te.vague::*}
    if {_next} is a player:
        te_setPlaying({_next})
    else:
        remove {_next} from {te.vague::*}
        te_nextPlayer()

function te_endGame():
    set {_winner} to first element of {te.joueurs::*}
    loop all players:
        if te_isInConfiguredWorld(loop-player) is true:
            set game mode of loop-player to adventure
            set {te.%uuid of loop-player%.playing} to false
    if {_winner} is a player:
        broadcast "{@prefix} &6☆ %{_winner}% &aremporte le Dé à Coudre ! Félicitations !"
        loop all players:
            if te_isInConfiguredWorld(loop-player) is true:
                send title "&6☆ %{_winner}%" with subtitle "&aremporte la partie !" to loop-player for 5 seconds
                play sound "ui.toast.challenge_complete" to loop-player
    else:
        broadcast "{@prefix} &cLa partie s'est terminée sans vainqueur."
    set {te.running} to false
    delete {te.joueurs::*}
    delete {te.vague::*}

function te_forceStop(stopper: text):
    loop all players:
        if te_isInConfiguredWorld(loop-player) is true:
            set {te.%uuid of loop-player%.playing} to false
            set game mode of loop-player to adventure
            send title "" with subtitle "&cLa partie a été arrêtée." to loop-player for 3 seconds
    broadcast "{@prefix} &cLa partie a été arrêtée par &f%{_stopper}%&c."
    set {te.running} to false
    delete {te.joueurs::*}
    delete {te.vague::*}

function te_countPlayersInWorld() :: number:
    set {_count} to 0
    loop all players:
        if te_isInConfiguredWorld(loop-player) is true:
            add 1 to {_count}
    return {_count}

function te_registerPlayers():
    loop all players:
        if te_isInConfiguredWorld(loop-player) is true:
            add loop-player to {te.joueurs::*}
            add loop-player to {te.vague::*}
            te_setWaiting(loop-player)

function te_countdown():
    loop 5 times:
        set {_t} to 6 - loop-number
        loop all players:
            if te_isInConfiguredWorld(loop-player) is true:
                heal loop-player
                set food level of loop-player to 20
                send title "&aLe Dé à Coudre commence !" with subtitle "&e%{_t}% seconde(s)..." to loop-player for 2 seconds
                play sound "block.note_block.pling" to loop-player
        wait 1 second

command /te [<text>]:
    permission: {@perm-admin}
    permission message: &cVous n'avez pas la permission d'exécuter cette commande.
    trigger:
        if te_isInConfiguredWorld(player) is not true:
            send "{@prefix} &cVous devez être dans le monde &a{@world-name}&c pour utiliser cette commande." to player
            stop
        if arg-1 is not set:
            send "" to player
            send " {@prefix} &7——— Thimble Event | Aide ———" to player
            send "  &f/te setspawn  &7→ Définit la plateforme de départ" to player
            send "  &f/te start     &7→ Lance la partie" to player
            send "  &f/te stop      &7→ Arrête la partie en cours" to player
            send "  &f/te info      &7→ Affiche l'état du jeu" to player
            send "" to player
            stop
        if arg-1 is "setspawn":
            set {te.spawn} to location of player
            send "{@prefix} &aPlateforme de départ définie avec succès." to player
            send "  &7Position: &fx=&f%x-coord of player%&7, y=&f%y-coord of player%&7, z=&f%z-coord of player%" to player
            stop
        if arg-1 is "info":
            send "" to player
            send " {@prefix} &7——— Statut du Dé à Coudre ———" to player
            if {te.running} is true:
                send "  &7Statut         : &aEn cours" to player
            else:
                send "  &7Statut         : &cArrêtée" to player
            send "  &7Joueurs en jeu : &f%size of {te.joueurs::*}%" to player
            send "  &7File d'attente : &f%size of {te.vague::*}%" to player
            if {te.spawn} is set:
                send "  &7Plateforme     : &aDéfinie" to player
            else:
                send "  &7Plateforme     : &cNon définie" to player
            send "" to player
            stop
        if arg-1 is "start":
            if {te.running} is true:
                send "{@prefix} &cUne partie est déjà en cours. Utilisez &f/te stop&c d'abord." to player
                stop
            if {te.spawn} is not set:
                send "{@prefix} &cAucune plateforme définie. Utilisez &f/te setspawn&c d'abord." to player
                stop
            if te_countPlayersInWorld() < 2:
                send "{@prefix} &cIl faut au moins &f2 joueurs&c dans le monde &a{@world-name}&c pour lancer une partie." to player
                stop
            set {te.running} to true
            delete {te.joueurs::*}
            delete {te.vague::*}
            send "{@prefix} &7Remplissage du bassin (rayon 100 blocs)..." to player
            loop all blocks in radius 100 around {te.spawn}:
                if type of loop-block is diorite:
                    set loop-block to water
            send "{@prefix} &aBassin prêt. Lancement du compte à rebours." to player
            te_countdown()
            te_registerPlayers()
            broadcast "{@prefix} &aLe Dé à Coudre a commencé ! &7(&f%size of {te.joueurs::*}% joueurs&7)"
            te_nextPlayer()
            stop
        if arg-1 is "stop":
            if {te.running} is not true:
                send "{@prefix} &cAucune partie n'est en cours." to player
                stop
            te_forceStop(name of player)
            stop
        make player execute command "/te"

on damage:
    if {te.running} is not true:
        stop
    if {te.%uuid of victim%.playing} is true:
        cancel event
        remove victim from {te.joueurs::*}
        te_setSpectating(victim)
        broadcast "{@prefix} &c%victim% &7a raté son saut et est éliminé ! &7(&f%size of {te.joueurs::*}% joueur(s) restant(s)&7)"
        te_nextPlayer()

on walk on wet sponge:
    if {te.running} is not true:
        stop
    if {te.%uuid of player%.playing} is true:
        set block above event-block to diorite
        te_setWaiting(player)
        send action bar "&a✔ Beau saut ! Retour en file d'attente." to player
        broadcast "{@prefix} &a%player% &7a réussi son saut !"
        te_nextPlayer()

on food level change:
    if {te.running} is not true:
        stop
    if {te.%uuid of player%.playing} is true:
        cancel event

on quit:
    if {te.running} is not true:
        stop
    if {te.%uuid of player%.playing} is true:
        remove player from {te.joueurs::*}
        remove player from {te.vague::*}
        set {te.%uuid of player%.playing} to false
        broadcast "{@prefix} &c%player% &7s'est déconnecté pendant son saut et est éliminé !"
        te_nextPlayer()
    else:
        remove player from {te.joueurs::*}
        remove player from {te.vague::*}
